# Target Platform
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_mt7981=y
CONFIG_TARGET_mediatek_mt7981_DEVICE_fzs_5gcpe-p3=y

# 编译基础设置
CONFIG_TARGET_ROOTFS_UBIFS=y
CONFIG_TARGET_ROOTFS_UBIFS_FREE_SPACE_FIXUP=y
CONFIG_TARGET_UBIFS_AUTO_MAXSIZE=y
CONFIG_BUSYBOX_CUSTOM=y
CONFIG_BUSYBOX_CONFIG_FEATURE_SYSLOG=y
CONFIG_BUSYBOX_CONFIG_FEATURE_WGET=y
CONFIG_BUSYBOX_CONFIG_IFUPDOWN=y
CONFIG_BUSYBOX_CONFIG_IP=y
CONFIG_BUSYBOX_CONFIG_NC=y
CONFIG_BUSYBOX_CONFIG_PING6=y
CONFIG_BUSYBOX_CONFIG_TRACEROUTE6=y
CONFIG_BUSYBOX_CONFIG_UDHCPC=y
CONFIG_BUSYBOX_CONFIG_UDHCPD=y

# 文件系统 & 闪存
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_kmod-fs-ubi=y
CONFIG_PACKAGE_kmod-mtd-rw=y
CONFIG_PACKAGE_ubi-utils=y
CONFIG_PACKAGE_uboot-envtools=y

# USB3 / 5G模组必备
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-usb-ohci=y
CONFIG_PACKAGE_kmod-usb-uhci=y
CONFIG_PACKAGE_usb-modeswitch=y
CONFIG_PACKAGE_usb-modeswitch-data=y

# 5G/4G 拨号工具（MBIM/QMI 模组通用）
CONFIG_PACKAGE_mbim-utils=y
CONFIG_PACKAGE_qmi-utils=y
CONFIG_PACKAGE_uqmi=y
CONFIG_PACKAGE_modemmanager=y
CONFIG_PACKAGE_luci-proto-modemmanager=y
CONFIG_PACKAGE_comgt=y
CONFIG_PACKAGE_luci-app-comgt=y

# MT7981 WiFi 驱动固件（和你device定义匹配）
CONFIG_PACKAGE_kmod-mt7981-firmware=y
CONFIG_PACKAGE_mt7981-wo-firmware=y
CONFIG_PACKAGE_wireless-regdb=y
CONFIG_PACKAGE_iw=y
CONFIG_PACKAGE_iw-full=y

# 网络基础
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_ip6tables=y
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-nossl=y
CONFIG_PACKAGE_openssl-util=y

# LuCI 中文Web界面
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-lib-ip=y
CONFIG_PACKAGE_luci-lib-jsonc=y
CONFIG_PACKAGE_luci-lib-nixio=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-network=y
CONFIG_PACKAGE_luci-firewall=y
CONFIG_PACKAGE_luci-wireless=y
CONFIG_PACKAGE_luci-system=y
CONFIG_PACKAGE_luci-statistics=y
CONFIG_PACKAGE_luci-app-opkg=y

# 系统工具
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_cfdisk=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_socat=y
CONFIG_PACKAGE_rsync=y

# 关闭无用节省空间
CONFIG_KERNEL_KALLSYMS=n
CONFIG_PACKAGE_vsftpd=n
CONFIG_PACKAGE_ddns-scripts_aliyun=n
CONFIG_PACKAGE_ddns-scripts_dnspod=n
CONFIG_PACKAGE_luci-app-v2raya=n
CONFIG_PACKAGE_luci-app-passwall=n
CONFIG_PACKAGE_luci-app-openclash=n
CONFIG_PACKAGE_mbedtls=n
CONFIG_PACKAGE_wpad-basic=n
CONFIG_PACKAGE_wpad-mesh-openssl=y
